# ─────────────────────────────────────────────────────────────────────────────
# Digital Therapy — environment variables
#
# Copy this file to `.env` (in this same folder) and fill in the values.
# `.env` is gitignored, so your secrets are never committed.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
# MySQL connection string from your database provider.
# Format:  mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
# Powers: admin login, the vendor inventory, and the contact form.
# After setting this, create the tables with:  npx drizzle-kit migrate
DATABASE_URL="mysql://user:password@host:3306/digital_therapy"

# ── Auth / platform (needed for admin login to actually work) ────────────────
# On a hosted platform (e.g. Manus) these are usually managed for you. For local
# login testing you'd copy them from your host's environment settings.
VITE_APP_ID=""
JWT_SECRET=""
OAUTH_SERVER_URL=""
# Your OAuth openId — the account with this id is auto-promoted to admin.
OWNER_OPEN_ID=""

# ── DT Portal mirror (optional) ──────────────────────────────────────────────
# Where vendor/contact submissions are also forwarded. Leave blank to disable.
PORTAL_INGEST_BASE=""
INGEST_SECRET=""
